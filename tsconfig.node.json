{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "vite.config.ts",
    "vite-plugin-hosts-api.ts",
    "vite-plugin-nginx-api.ts",
    "vite-plugin-apache-api.ts",
    "vite-plugin-terminal-ws.ts",
    "vite-plugin-db-test-api.ts",
    "vite-plugin-redis-browser-api.ts",
    "vite-plugin-postgres-browser-api.ts",
    "vite-plugin-postgres-admin-api.ts",
    "privileged-write.ts"
  ]
}
